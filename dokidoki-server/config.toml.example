[server]
host = "0.0.0.0"
port = 8080

[auth]
# MVP：无静态 api_tokens；Token 由注册/登录写入 user_sessions
password_cost = 12                    # argon2 cost
token_prefix = "doki_"

[database]
url = "mysql://dokidoki:password@mysql:3306/dokidoki"

[llm]
mode = "fake"                           # fake | http
fake_default = "[REPLY] 你好，我是测试角色"
base_url = "https://api.deepseek.com/v1"
api_key = "sk-..."
model = "deepseek-chat"
vision_model = "deepseek-chat"        # 支持 vision 时填写

[upload]
dir = "/data/uploads"                   # 角色头像在 avatars/ 子目录
max_bytes = 10485760                  # 10MB
allowed_types = ["image/jpeg", "image/png", "image/webp"]

[chat]
burst_silence_ms = 2000
bubble_delay_base_ms = 400
bubble_delay_per_char_ms = 50

# M-15 忙碌回复延迟：reply_wait = sample(availability) × reply_delay_factor × jitter
# reply_delay_factor 来自角色 persona_json.reply_delay_factor（[min, max]），缺省 1.0
# 最终不超过当前活动段剩余时长。时间单位均为秒。
[chat.reply_delay]
# high：空闲，短延迟
high_min_secs = 0.3
high_max_secs = 2.0
# medium：一般忙碌
medium_min_secs = 30.0
medium_max_secs = 300.0
# low：很忙，三段加权抽样（short / mid / long）
low_short_min_secs = 60.0                   # 短延迟桶：uniform(min, max)
low_short_max_secs = 300.0
low_mid_min_secs = 300.0                    # 中延迟桶：uniform(min, 活动剩余)
low_mid_default_remaining_secs = 600.0      # 无 activity_ends_at 时用的默认活动剩余
low_mid_cap_min_secs = 300.0                # 对活动剩余做 clamp 的下限
low_mid_cap_max_secs = 3600.0               # 对活动剩余做 clamp 的上限
low_long_default_remaining_secs = 300.0     # 长延迟桶：等到活动结束；无 ends_at 时的默认值
low_long_clamp_min_secs = 60.0              # 长延迟结果 clamp 下限
low_long_clamp_max_secs = 7200.0            # 长延迟结果 clamp 上限
low_short_weight_pct = 30                   # 短延迟桶权重 %
low_mid_weight_pct = 45                     # 中延迟桶权重 %；剩余归入长延迟桶
# 全局抖动（角色性格系数见 persona_json.reply_delay_factor）
jitter_min = 0.85
jitter_max = 1.15

[summary]
trigger_turns = 80
keep_recent_turns = 40
max_summary_chars = 800

[push]
fcm_credentials_path = "/secrets/fcm.json"   # 可选

[proactive]
default_max_per_day = 20
# 各 availability 基础触发概率（再乘 persona_json.proactive.probability_factor）
availability_high = 0.45
availability_medium = 0.25
availability_low = 0.05
# 起床活动段开始后，在 [min, max] 分钟内随机取窗；进窗后至多每日问候一次
daily_greeting_window_min_mins = 0
daily_greeting_window_max_mins = 15